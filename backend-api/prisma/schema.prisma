// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Stores the Smartcar OAuth tokens for the Mach-E so we don't have to
/// send the user through the Ford login every time the app opens.
/// Singleton row for the linked EV (Smartcar). `id` is always `default`.
model VehicleToken {
  id              String    @id @default("default")
  vehicleId       String?
  accessToken     String
  refreshToken    String
  accessExpiresAt DateTime?
  updatedAt       DateTime  @updatedAt
}

/// Singleton row describing the currently active road trip. The fixed
/// `id` default guarantees only one active trip can exist at a time,
/// which lets us cheaply enforce "only one driver / one passenger".
model TripSession {
  id            String  @id @default("current_trip")
  driverName    String?
  passengerName String?
  activeTheme   String  @default("Phineas")
  // JSON-encoded array of Safe Check-In events (arrived / vibe / leaving /
  // blackout). Stored as a plain string so we don't need a Postgres-only
  // Json column. See /api/check-in for the schema of each entry.
  checkInLogJson String @default("[]")
  // Shared trip expense ledger (food, coffee, charging). See /api/expenses.
  expenseLedgerJson String @default("[]")
  updatedAt     DateTime @updatedAt
}

/// Leaderboard entry. `gameType` is "IntricateLie" or "GhostWord".
model GameScore {
  id        String   @id @default(cuid())
  player    String
  points    Int      @default(0)
  gameType  String
  createdAt DateTime @default(now())

  @@index([gameType, points])
}
