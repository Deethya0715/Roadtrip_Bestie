// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// A player. Optionally linked to a Smartcar vehicle via the access token
/// that was exchanged in /api/auth/callback.
model User {
  id                    String      @id @default(cuid())
  email                 String      @unique
  displayName           String?
  smartcarAccessToken   String?
  smartcarRefreshToken  String?
  smartcarTokenExpires  DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  scores                GameScore[]
  locations             Location[]
}

/// Leaderboard entry. `game` lets us reuse one table across Ghost Word
/// Chain, Hider's Vault, I-Spy, etc.
model GameScore {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      String
  score     Int
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([game, score])
  @@index([userId])
}

/// Hider's Vault — a geotagged drop (photo/note/clue) left by a user
/// that other players can try to find.
model Location {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  latitude    Float
  longitude   Float
  note        String?
  photoUrl    String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([latitude, longitude])
  @@index([userId])
}
